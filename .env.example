# ---------------------------------------------------------------------------
# Ray Render Farm — standalone configuration. Copy to .env and edit.
#     cp .env.example .env
# Used by setup_infra.sh / deploy_app.sh / verify_setup.sh ONLY. The Hub does
# NOT read this file — it supplies its own NAMESPACE/PROJECT_NAME/REGION/
# ARTIFACT_REGISTRY_REPO and drives the feature via feature.yaml.
# ---------------------------------------------------------------------------

# Google Cloud project id. (Standalone uses PROJECT_ID; the Hub injects the
# equivalent as PROJECT_NAME — see feature.yaml template_defaults.)
PROJECT_ID=your-gcp-project-id

# GKE cluster + gateway. Use a DISTINCT cluster name so you never touch an
# existing one. GATEWAY_NAME must match metadata.name in infra/gateway.yaml.
CLUSTER_NAME=ray-render-farm-cluster
GATEWAY_NAME=ray-render-gw

# Region / zone. REGION defaults to ZONE without its trailing -<letter>.
REGION=us-central1
ZONE=us-central1-a

# Small on-demand DEFAULT node pool. It hosts the KubeRay operator, the Ray head,
# and the controller. Ray WORKERS run on auto-provisioned Spot nodes selected by
# the ray-spot ComputeClass (cluster/spot-computeclass.yaml), not this pool.
MACHINE_TYPE=e2-standard-4
NUM_NODES=2

# Node Auto-Provisioning limits. NAP must be enabled so the ray-spot ComputeClass
# can auto-create Spot node pools on demand for the Ray workers.
MAX_CPU=200
MAX_MEMORY=800

# RayCluster worker autoscaling bounds (the live "worker cap"). min 0 lets the
# cluster scale to zero workers when idle.
WORKER_MIN_REPLICAS=0
WORKER_MAX_REPLICAS=6

# Per-namespace deploy target. Keep "default" for standalone so ${NAMESPACE} in
# the manifests still renders; the Hub overrides this with gke-showcase-ray.
NAMESPACE=default

# Artifact Registry repo for the image (created by deploy_app.sh if missing).
ARTIFACT_REGISTRY_REPO=ray-render-farm

# Optional: image tag. Defaults to CLUSTER_NAME so multiple clusters never share
# a :latest and clobber each other's image.
# IMAGE_TAG=ray-render-farm-cluster

# Controller HTTP port.
APP_PORT=8000
